<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/background_light"
    tools:context=".selectActivity">

    <ImageView
        android:id="@+id/pdfeview"
        android:layout_width="162dp"
        android:layout_height="161dp"
        android:layout_marginStart="124dp"
        android:layout_marginTop="440dp"
        android:layout_marginEnd="125dp"
        android:onClick="ImageCreate"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/pdf_logo" />

    <TextView
        android:id="@+id/textView3"
        android:layout_width="248dp"
        android:layout_height="49dp"

        android:layout_marginStart="82dp"
        android:layout_marginEnd="82dp"
        android:layout_marginBottom="81dp"
        android:onClick="create"
        android:text="CREATE PDF"
        android:textAlignment="center"
        android:textColor="#000000"
        android:textSize="40sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/pdfeview"
        app:layout_constraintVertical_bias="0.0" />

    <ImageView
        android:id="@+id/preview"
        android:layout_width="162dp"
        android:layout_height="161dp"
       android:onClick="viewPdf"
        android:layout_marginStart="125dp"
        android:layout_marginTop="154dp"
        android:layout_marginEnd="124dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_baseline_preview_24" />

    <TextView
        android:id="@+id/textView4"
        android:layout_width="248dp"
        android:layout_height="49dp"
        android:layout_marginStart="81dp"
        android:layout_marginEnd="82dp"
        android:onClick="Pdfview"
        android:text="VIEW PDF"
        android:textAlignment="center"
        android:textColor="@color/design_default_color_on_secondary"
        android:textSize="40sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/preview" />
</androidx.constraintlayout.widget.ConstraintLayout>